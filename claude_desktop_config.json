{
  "mcpServers": {
    "filesystem": {
      "command": "node",
      "args": [
        "C:/mcp-servers/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "C:/",
        "E:/ZETA/Tallyio"
      ]
    },
    "brave-search": {
      "command": "node",
      "args": [
        "C:/mcp-servers/node_modules/@modelcontextprotocol/server-brave-search/dist/index.js"
      ],
      "env": {
        "BRAVE_API_KEY": "your-brave-api-key-here"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "C:/mcp-servers/node_modules/@modelcontextprotocol/server-github/dist/index.js"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your-github-token-here"
      }
    },
    "context7": {
      "command": "node",
      "args": [
        "C:/mcp-servers/context7/dist/index.js"
      ],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "10000"
      }
    },
    "taskmaster-ai": {
      "command": "npx",
      "args": ["-y", "--package=task-master-ai", "task-master-ai"],

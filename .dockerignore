# 🚀 TallyIO Docker Build Optimization
# Exclude unnecessary files to speed up Docker builds

# ============================================================================
# 🎯 Build artifacts and cache
# ============================================================================
target/
Cargo.lock
**/*.rs.bk
**/*.pdb

# ============================================================================
# 🔧 Development files
# ============================================================================
.git/
.gitignore
.github/
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# 📋 Documentation and examples
# ============================================================================
README.md
CHANGELOG.md
LICENSE
docs/
examples/
*.md

# ============================================================================
# 🧪 Testing and CI
# ============================================================================
tests/
benches/
.coverage/
coverage/
*.profraw
*.profdata

# ============================================================================
# 🌐 Frontend and web assets (if not needed in container)
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
dist/
build/

# ============================================================================
# 🔧 Configuration and secrets
# ============================================================================
.env
.env.local
.env.*.local
config/local/
config/development/
config/test/
*.key
*.pem
*.crt

# ============================================================================
# 📊 Logs and temporary files
# ============================================================================
logs/
*.log
tmp/
temp/
.tmp/

# ============================================================================
# 🐳 Docker files (avoid recursion)
# ============================================================================
Dockerfile*
.dockerignore
docker-compose*.yml

# ============================================================================
# 📦 Package manager files
# ============================================================================
.cargo/
.rustup/

# ============================================================================
# 🔍 IDE and editor files
# ============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.sublime-*
.editorconfig

# ============================================================================
# 🚀 Deployment and infrastructure
# ============================================================================
deployment/
k8s/
terraform/
ansible/
scripts/
monitoring/

# ============================================================================
# 📈 Monitoring and metrics
# ============================================================================
grafana/
prometheus/
*.db
*.sqlite

# ============================================================================
# 🔒 Security and audit files
# ============================================================================
audit-*.json
security-*.json
*.audit

# ============================================================================
# 📱 Mobile and platform specific
# ============================================================================
.flutter-plugins
.flutter-plugins-dependencies
.dart_tool/
.packages
pubspec.lock

# ============================================================================
# 🎮 Game engines and assets
# ============================================================================
*.unity
*.unitypackage

# ============================================================================
# 📊 Data and databases
# ============================================================================
*.db
*.sqlite
*.sqlite3
data/
migrations/
seeds/

# ============================================================================
# 🔧 Build tools and scripts
# ============================================================================
Makefile
justfile
.make/
scripts/
tools/

# ============================================================================
# 📋 Project management
# ============================================================================
.project
.classpath
.settings/
.metadata/

# ============================================================================
# 🌍 Internationalization
# ============================================================================
*.po
*.pot
locale/
translations/

# ============================================================================
# 📸 Media files
# ============================================================================
*.jpg
*.jpeg
*.png
*.gif
*.svg
*.ico
*.webp
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mp3
*.wav
*.ogg

# ============================================================================
# 📚 Archives and compressed files
# ============================================================================
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.rar
*.7z

# ============================================================================
# 🔄 Version control
# ============================================================================
.git/
.svn/
.hg/
.bzr/
CVS/

# ============================================================================
# 🎯 TallyIO specific exclusions
# ============================================================================
context/
tasks/
*.bat
claude_desktop_config*.json
complete_config.json
MCP_README.md
start-*.bat
